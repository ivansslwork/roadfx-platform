# RoadFX Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit .env to git!

# ============================================
# Firebase Configuration
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=roadfx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=roadfx
VITE_FIREBASE_STORAGE_BUCKET=roadfx.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc

# ============================================
# PayPal Configuration
# ============================================
# Sandbox (test first!): https://developer.paypal.com
VITE_PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id
VITE_PAYPAL_ENVIRONMENT=sandbox

# Production:
# VITE_PAYPAL_CLIENT_ID=your_paypal_live_client_id
# VITE_PAYPAL_ENVIRONMENT=production

# ============================================
# RoadFX API
# ============================================
VITE_ROADFX_API_URL=https://api.roadfx.io
VITE_FORGE_REPO_URL=https://forge.mql5.io/ivan_i_82/roadfx-mql5

# ============================================
# AI Agent API Keys (for production)
# ============================================
VITE_ANTHROPIC_API_KEY=sk-ant-xxx
VITE_OPENAI_API_KEY=sk-xxx
VITE_GOOGLE_AI_API_KEY=AIza...
VITE_DEEPSEEK_API_KEY=sk-xxx

# ============================================
# Analytics & SEO
# ============================================
VITE_GA_MEASUREMENT_ID=G-XXXXXXX
VITE_SITE_URL=https://roadfx.app
VITE_SITE_NAME=RoadFX

# ============================================
# Support
# ============================================
VITE_SUPPORT_WHATSAPP=62838520326060
VITE_FOUNDER_TWITTER=https://twitter.com/ivansslo
VITE_ADMIN_EMAIL=roadfrx@gmail.com
